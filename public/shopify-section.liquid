{% comment %}
  RiskSim — Supply Chain Intelligence Platform
  Shopify Storefront Section

  Installation:
  1. Copy this file into your Shopify theme under: sections/risksim-embed.liquid
  2. In your theme's JSON template (e.g. templates/index.json), add the section:
       "risksim": { "type": "risksim-embed", "settings": {} }
  3. In the Shopify Theme Editor you can enable/disable and adjust height.
{% endcomment %}

<style>
  .risksim-section {
    width: 100%;
    background: #000;
    padding: 0;
    margin: 0;
  }

  .risksim-section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    background: #000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .risksim-section__title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.2px;
  }

  .risksim-section__subtitle {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
    font-size: 12px;
    color: #555;
    margin-top: 2px;
  }

  .risksim-section__badge {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.05);
  }

  .risksim-section__badge-dot {
    width: 7px;
    height: 7px;
    background: #fff;
    border-radius: 50%;
    animation: risksim-pulse 2s ease-in-out infinite;
  }

  .risksim-section__badge-text {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
  }

  @keyframes risksim-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .risksim-section__embed {
    width: 100%;
    border: none;
    display: block;
    background: #000;
  }
</style>

<section class="risksim-section">
  {% if section.settings.show_header %}
  <div class="risksim-section__header">
    <div>
      <div class="risksim-section__title">
        {% if section.settings.title != blank %}
          {{ section.settings.title }}
        {% else %}
          Supply Chain Risk Intelligence
        {% endif %}
      </div>
      {% if section.settings.subtitle != blank %}
      <div class="risksim-section__subtitle">{{ section.settings.subtitle }}</div>
      {% endif %}
    </div>
    <div class="risksim-section__badge">
      <div class="risksim-section__badge-dot"></div>
      <span class="risksim-section__badge-text">Live Analysis</span>
    </div>
  </div>
  {% endif %}

  <iframe
    class="risksim-section__embed"
    src="{{ section.settings.embed_url | default: 'https://risksim-backend.onrender.com' }}"
    height="{{ section.settings.height | default: 720 }}"
    loading="lazy"
    title="RiskSim Supply Chain Intelligence Platform"
    allow="clipboard-write"
  ></iframe>
</section>

{% schema %}
{
  "name": "RiskSim Embed",
  "tag": "section",
  "class": "risksim-embed-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Supply Chain Risk Intelligence"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Powered by Claude AI · 70+ Countries Monitored · Real-Time Analysis"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header bar",
      "default": false
    },
    {
      "type": "url",
      "id": "embed_url",
      "label": "RiskSim App URL",
      "info": "The URL of your deployed RiskSim instance (e.g. https://risksim-backend.onrender.com)"
    },
    {
      "type": "range",
      "id": "height",
      "min": 400,
      "max": 1200,
      "step": 40,
      "unit": "px",
      "label": "Embed Height",
      "default": 720
    }
  ],
  "presets": [
    {
      "name": "RiskSim Intelligence Panel",
      "category": "Custom"
    }
  ]
}
{% endschema %}
